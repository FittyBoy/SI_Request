<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<location path="." inheritInChildApplications="false">
    <system.webServer>
        <handlers>
				<add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
        </handlers>

			<!-- AspNetCore Configuration -->
			<aspNetCore processPath="dotnet"
						arguments=".\SI24004.dll"
						stdoutLogEnabled="true"
						stdoutLogFile=".\logs\stdout"
						hostingModel="InProcess"
						startupTimeLimit="120"
						shutdownTimeLimit="30">
				<environmentVariables>
					<environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
					<environmentVariable name="ASPNETCORE_URLS" value="http://*:9011" />
				</environmentVariables>
			</aspNetCore>

			<!-- HTTP Errors - ???? error ?????????? -->
			<httpErrors errorMode="Detailed" />

			<!-- Request Filtering -->
			<security>
				<requestFiltering>
					<requestLimits maxAllowedContentLength="524288000" />
				</requestFiltering>
			</security>

			<!-- Default Document -->
			<defaultDocument enabled="true">
				<files>
					<clear />
					<add value="index.html" />
				</files>
			</defaultDocument>

			<!-- Static Content -->
			<staticContent>
				<remove fileExtension=".json" />
				<mimeMap fileExtension=".json" mimeType="application/json" />
			</staticContent>

        <!-- ✅ เพิ่ม Headers สำหรับ CORS -->
        <httpProtocol>
            <customHeaders>
                <add name="Access-Control-Allow-Origin" value="http://172.18.106.100:8083" />
                <add name="Access-Control-Allow-Methods" value="GET, POST, PUT, DELETE, OPTIONS" />
                <add name="Access-Control-Allow-Headers" value="Content-Type, Authorization" />
                <add name="Access-Control-Allow-Credentials" value="true" />
            </customHeaders>
        </httpProtocol>
    </system.webServer>
	</location>

	<!-- ?? system.web ??? ???????????????????? ASP.NET Core -->

</configuration>
